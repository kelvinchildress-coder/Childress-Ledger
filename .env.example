# Copy this file to .env (gitignored) for local dev, or set these in Vercel/Netlify/Cloudflare project settings.
# Both are optional — the app still works without them, falling back to per-device Settings.

# Default Apps Script Web App URL. Bakes into the build, so every installed PWA already knows your backend.
VITE_BACKEND_URL=

# Optional shared secret. Must match SHARED_SECRET in your Apps Script Script Properties.
# Adds a tiny defense-in-depth check on top of the URL secrecy.
VITE_SHARED_SECRET=
